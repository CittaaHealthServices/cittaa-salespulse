# ─── Cittaa SalesPulse — Environment Variables ─────────────────────────────────
# Copy this to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# MongoDB Atlas
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/

# Google Gemini API
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Frontend URL (used for CORS — set to Railway URL in production)
FRONTEND_URL=http://localhost:5173

# App public URL (used in email links — set to your Railway URL)
APP_URL=https://YOUR_APP.up.railway.app

# Resend (transactional email)
# Sign up at https://resend.com — free tier = 3000 emails/month
# Add and verify your domain in Resend dashboard first
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM=SalesPulse <no-reply@cittaa.in>
